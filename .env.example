# Скопируйте в .env.local и заполните. .env.local в git не попадает.
# Всё, что не начинается с NEXT_PUBLIC_, доступно только на сервере.

# Публичный адрес сайта — нужен для метаданных, OG и sitemap
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase: таблица лидов
NEXT_PUBLIC_SUPABASE_URL=""
# Service role, НЕ anon. Запись только через Route Handler, никогда с клиента.
SUPABASE_SERVICE_ROLE_KEY=""

# Upstash Redis: rate limit на /api/lead
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Яндекс.Метрика: номер счётчика
NEXT_PUBLIC_YM_ID=""
